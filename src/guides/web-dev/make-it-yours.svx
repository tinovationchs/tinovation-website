---
title: Personalize Your Website with Interactive Effects
authors: [Tinovation]
date: "2026-07-12"
checked: true
published: true
---

<script>
  import { onDestroy, onMount, tick } from "svelte";

  let backgroundMode = "grid";
  let typedTarget;
  let preview;
  let typedInstance;
  let tippyInstances = [];
  let sparkles = [];
  let sparkleId = 0;
  let animeTarget;
  let matterHost;
  let matterEngine;
  let matterRender;
  let matterRunner;
  let renderEnabled = true;

  // --- Page Destroy Variables ---
  let pageDestroyEngine;
  let pageDestroyRunner;
  let pageDestroyRaf;
  let pageDestroyOriginals = new Map();
  let pageDestroyElements = [];

  const sparkleChars = ["*", "+", "o", "<3"];
  const scriptCache = new Map();

  const loadScript = (src) => {
    if (scriptCache.has(src)) return scriptCache.get(src);

    const promise = new Promise((resolve, reject) => {
      const existing = document.querySelector(`script[src="${src}"]`);
      if (existing) {
        resolve(true);
        return;
      }

      const script = document.createElement("script");
      script.src = src;
      script.async = true;
      script.onload = () => resolve(true);
      script.onerror = reject;
      document.head.appendChild(script);
    });

    scriptCache.set(src, promise);
    return promise;
  };

  const makeSparkle = (event) => {
    if (!preview || Math.random() > 0.5) return;

    const rect = preview.getBoundingClientRect();
    const x = event.clientX - rect.left;
    const y = event.clientY - rect.top;
    const id = sparkleId++;

    sparkles = [
      ...sparkles,
      {
        id,
        x,
        y,
        char: sparkleChars[Math.floor(Math.random() * sparkleChars.length)],
      },
    ];

    setTimeout(() => {
      sparkles = sparkles.filter((sparkle) => sparkle.id !== id);
    }, 700);
  };

  const runConfetti = () => {
    if (!window.confetti) return;

    window.confetti({
      particleCount: 90,
      spread: 78,
      origin: { y: 0.72 },
      colors: ["#f472b6", "#f9a8d4", "#a78bfa", "#60a5fa", "#facc15"],
    });
  };

  const runAnimeDemo = () => {
    if (!window.anime || !animeTarget) return;

    window.anime({
      targets: animeTarget,
      translateY: [-8, -32, -8],
      scale: [1, 1.2, 1],
      rotate: ["0deg", "10deg", "-10deg", "0deg"],
      duration: 900,
      easing: "easeInOutSine",
    });
  };

  const destroyMatterDemo = () => {
    if (matterRender) {
      window.Matter?.Render.stop(matterRender);
      matterRender.canvas?.remove();
      matterRender.textures = {};
      matterRender = undefined;
    }

    if (matterRunner) {
      window.Matter?.Runner.stop(matterRunner);
      matterRunner = undefined;
    }

    if (matterEngine) {
      window.Matter?.World.clear(matterEngine.world, false);
      window.Matter?.Engine.clear(matterEngine);
      matterEngine = undefined;
    }
  };

  const initMatterDemo = () => {
    if (!window.Matter || !matterHost || !renderEnabled) return;

    destroyMatterDemo();

    const { Engine, Render, Runner, Bodies, Composite } = window.Matter;
    const width = Math.max(280, Math.floor(matterHost.clientWidth));
    const height = 220;

    matterEngine = Engine.create();
    matterRender = Render.create({
      element: matterHost,
      engine: matterEngine,
      options: {
        width,
        height,
        wireframes: false,
        background: "transparent",
      },
    });

    const ground = Bodies.rectangle(width / 2, height + 20, width, 40, { isStatic: true });
    const leftWall = Bodies.rectangle(-10, height / 2, 20, height, { isStatic: true });
    const rightWall = Bodies.rectangle(width + 10, height / 2, 20, height, { isStatic: true });

    const starterBall = Bodies.circle(width / 2, 40, 16, {
      restitution: 0.8,
      render: { fillStyle: "#f472b6" },
    });

    Composite.add(matterEngine.world, [ground, leftWall, rightWall, starterBall]);

    matterRunner = Runner.create();
    Runner.run(matterRunner, matterEngine);
    Render.run(matterRender);
  };

  const dropMatterShape = () => {
    if (!window.Matter || !matterEngine || !matterHost) return;

    const { Bodies, Composite } = window.Matter;
    const width = Math.max(280, Math.floor(matterHost.clientWidth));
    const x = 30 + Math.random() * (width - 60);

    const shape =
      Math.random() > 0.5
        ? Bodies.circle(x, 20, 12 + Math.random() * 8, {
            restitution: 0.75,
            render: { fillStyle: "#60a5fa" },
          })
        : Bodies.rectangle(x, 20, 18, 18, {
            restitution: 0.65,
            angle: Math.random(),
            render: { fillStyle: "#a78bfa" },
          });

    Composite.add(matterEngine.world, shape);
  };

  // --- Page Destroy Implementation ---
  const triggerPageDestroy = () => {
    if (!window.Matter) return;
    if (pageDestroyEngine) return; // already active

    const { Engine, Runner, Bodies, Composite } = window.Matter;
    
    // Select candidates to drop
    const candidates = Array.from(document.querySelectorAll('h1, h2, h3, p, pre, li, .tilt-card, .matter-host, .controls button, .mini-btn, table'));
    
    // Filter out elements that are inside another candidate so we don't apply physics twice to nested elements
    const topLevelCandidates = candidates.filter(el => {
      let parent = el.parentElement;
      while (parent && parent !== document.body) {
        if (candidates.includes(parent)) return false;
        parent = parent.parentElement;
      }
      return true;
    });

    // Exclude our destroy controls to keep them usable
    pageDestroyElements = topLevelCandidates.filter(el => !el.closest('.page-destroy-controls') && el.getBoundingClientRect().height > 0);

    // Save original styles
    pageDestroyElements.forEach(el => {
      const rect = el.getBoundingClientRect();
      pageDestroyOriginals.set(el, {
        position: el.style.position,
        left: el.style.left,
        top: el.style.top,
        width: el.style.width,
        height: el.style.height,
        margin: el.style.margin,
        transform: el.style.transform,
        transition: el.style.transition,
        zIndex: el.style.zIndex,
        rect: rect,
        centerX: rect.left + rect.width / 2,
        centerY: rect.top + rect.height / 2
      });
    });

    // Make elements fixed position
    pageDestroyElements.forEach(el => {
      const state = pageDestroyOriginals.get(el);
      el.style.position = 'fixed';
      el.style.left = `${state.rect.left}px`;
      el.style.top = `${state.rect.top}px`;
      el.style.width = `${state.rect.width}px`;
      el.style.height = `${state.rect.height}px`;
      el.style.margin = '0';
      el.style.transition = 'none';
      el.style.zIndex = '9999';
    });

    // Create physics world
    pageDestroyEngine = Engine.create();
    const bodies = pageDestroyElements.map(el => {
      const state = pageDestroyOriginals.get(el);
      const body = Bodies.rectangle(
        state.centerX,
        state.centerY,
        state.rect.width,
        state.rect.height,
        {
          restitution: 0.6,
          friction: 0.3,
          frictionAir: 0.02
        }
      );
      body.domElement = el;
      body.initialCenterX = state.centerX;
      body.initialCenterY = state.centerY;
      return body;
    });

    const ground = Bodies.rectangle(window.innerWidth / 2, window.innerHeight + 50, window.innerWidth * 2, 100, { isStatic: true });
    const leftWall = Bodies.rectangle(-50, window.innerHeight / 2, 100, window.innerHeight * 2, { isStatic: true });
    const rightWall = Bodies.rectangle(window.innerWidth + 50, window.innerHeight / 2, 100, window.innerHeight * 2, { isStatic: true });

    Composite.add(pageDestroyEngine.world, [...bodies, ground, leftWall, rightWall]);

    pageDestroyRunner = Runner.create();
    Runner.run(pageDestroyRunner, pageDestroyEngine);

    // Render loop syncing physics bodies to DOM
    const updateDom = () => {
      if (!pageDestroyEngine) return;
      bodies.forEach(body => {
        const el = body.domElement;
        const dx = body.position.x - body.initialCenterX;
        const dy = body.position.y - body.initialCenterY;
        el.style.transform = `translate(${dx}px, ${dy}px) rotate(${body.angle}rad)`;
      });
      pageDestroyRaf = requestAnimationFrame(updateDom);
    };
    updateDom();
  };

  const resetPageDestroy = () => {
    if (!pageDestroyEngine) return;

    if (pageDestroyRunner) window.Matter?.Runner.stop(pageDestroyRunner);
    window.Matter?.Engine.clear(pageDestroyEngine);
    if (pageDestroyRaf) cancelAnimationFrame(pageDestroyRaf);

    // Restore original styles
    pageDestroyElements.forEach(el => {
      const state = pageDestroyOriginals.get(el);
      if (state) {
        el.style.position = state.position;
        el.style.left = state.left;
        el.style.top = state.top;
        el.style.width = state.width;
        el.style.height = state.height;
        el.style.margin = state.margin;
        el.style.transform = state.transform;
        el.style.transition = state.transition;
        el.style.zIndex = state.zIndex;
      }
    });

    pageDestroyOriginals.clear();
    pageDestroyElements = [];
    pageDestroyEngine = null;
    pageDestroyRunner = null;
  };
  // -----------------------------------

  const initEnhancements = async () => {
    typedInstance?.destroy();
    typedInstance = undefined;

    tippyInstances.forEach((instance) => instance.destroy());
    tippyInstances = [];

    if (window.Typed && typedTarget) {
      typedInstance = new window.Typed(typedTarget, {
        strings: [
          "performance-aware motion",
          "interactive cards and tooltips",
          "event-driven visual feedback",
          "beginner-friendly UI patterns",
        ],
        typeSpeed: 44,
        backSpeed: 24,
        backDelay: 900,
        loop: true,
      });
    }

    if (window.VanillaTilt) {
      window.VanillaTilt.init(document.querySelectorAll(".tilt-card, .tilt-demo"), {
        max: 10,
        speed: 320,
        glare: true,
        "max-glare": 0.22,
      });
    }

    if (window.tippy) {
      tippyInstances = window.tippy("[data-tip]", {
        theme: "custom-pink",
        animation: "shift-away",
      });
    }

    initMatterDemo();
  };

  const destroyBlogPost = () => {
    renderEnabled = false;
    typedInstance?.destroy();
    typedInstance = undefined;
    tippyInstances.forEach((instance) => instance.destroy());
    tippyInstances = [];
    destroyMatterDemo();
    resetPageDestroy();
  };

  const rebuildBlogPost = async () => {
    renderEnabled = false;
    await tick();
    renderEnabled = true;
    await tick();
    await initEnhancements();
  };

  onMount(async () => {
    await Promise.all([
      loadScript("https://cdn.jsdelivr.net/npm/typed.js@2.1.0/dist/typed.umd.js"),
      loadScript(
        "https://cdn.jsdelivr.net/npm/vanilla-tilt@1.8.1/dist/vanilla-tilt.min.js"
      ),
      loadScript(
        "https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"
      ),
      loadScript("https://cdn.jsdelivr.net/npm/animejs@3.2.2/lib/anime.min.js"),
      loadScript("https://cdn.jsdelivr.net/npm/matter-js@0.20.0/build/matter.min.js"),
      loadScript("https://unpkg.com/@popperjs/core@2"),
      loadScript("https://unpkg.com/tippy.js@6/dist/tippy-bundle.umd.min.js"),
    ]);

    await initEnhancements();
  });

  onDestroy(() => {
    typedInstance?.destroy();
    tippyInstances.forEach((instance) => instance.destroy());
    destroyMatterDemo();
    resetPageDestroy();
  });
</script>

<svelte:head>
  <link rel="stylesheet" href="https://unpkg.com/tippy.js@6/themes/light.css" />
</svelte:head>

<div class="blog-bg {backgroundMode}" role="presentation" />

<div class="lifecycle-controls">
  <button class="mini-btn" on:click={destroyBlogPost}>Destroy blog post</button>
  <button class="mini-btn" on:click={rebuildBlogPost}>Rebuild blog post</button>
</div>

{#if renderEnabled}
This guide is a beginner-oriented technical walkthrough for adding interactive front-end effects.
Each feature below has:

1. a short explanation,
2. a live demo on this page, and
3. a code snippet you can reuse.

## Learning goal

By the end, you should understand how to:

- load third-party libraries safely,
- map effects to user events,
- keep styles readable,
- and avoid common performance issues.

## Page-level background modes (live)

These controls update the background of the **entire blog page**, not just a small box.

<div class="controls">
  <button class:active={backgroundMode === "grid"} on:click={() => (backgroundMode = "grid")}>
    Grid background
  </button>
  <button class:active={backgroundMode === "dots"} on:click={() => (backgroundMode = "dots")}>
    Dot background
  </button>
  <button class:active={backgroundMode === "waves"} on:click={() => (backgroundMode = "waves")}>
    Gradient background
  </button>
  <button on:click={runConfetti}>Trigger success effect</button>
</div>

```ts
let backgroundMode = "grid";
// Example in Svelte:
// <div class="blog-bg {backgroundMode}" />
// on:click={() => (backgroundMode = "dots")}
```

## Library demos with technical usage

### 1) [canvas-confetti](https://www.npmjs.com/package/canvas-confetti)

Use case: user finishes an important action (submit, deploy, pass a quiz).

<button class="mini-btn" on:click={runConfetti}>Run confetti burst</button>

```js
window.confetti({
  particleCount: 90,
  spread: 78,
  origin: { y: 0.72 },
  colors: ["#f472b6", "#a78bfa", "#60a5fa"],
});
```

Implementation note: trigger this on meaningful events only, not on every click.

### 2) [VanillaTilt.js](https://micku7zu.github.io/vanilla-tilt.js/)

Use case: make cards feel interactive without complex 3D code.

<span class="tilt-demo">Hover this card token</span>

```js
window.VanillaTilt.init(document.querySelectorAll(".tilt-card"), {
  max: 10,
  speed: 320,
  glare: true,
  "max-glare": 0.22,
});
```

Implementation note: apply to small card components, not full text containers.

### 3) [Typed.js](https://mattboldt.com/demos/typed-js/)

Use case: rotate through project tags, values, or call-to-action phrases.

<span class="typed-line">Typed preview: <span class="typed-target" bind:this={typedTarget} /></span>

```js
const typed = new window.Typed(targetElement, {
  strings: ["fast onboarding", "project-based learning", "clear feedback"],
  typeSpeed: 44,
  backSpeed: 24,
  loop: true,
});
```

Implementation note: remember to destroy the instance when the component unmounts.

### 4) [anime.js](https://animejs.com/)

Use case: run controlled timeline animations for badges, icons, or onboarding cues.

<span class="anime-demo-wrap">
  <button class="mini-btn" on:click={runAnimeDemo}>Animate indicator</button>
  <span class="anime-dot" bind:this={animeTarget} />
</span>

```js
window.anime({
  targets: ".status-dot",
  translateY: [-8, -32, -8],
  scale: [1, 1.2, 1],
  duration: 900,
  easing: "easeInOutSine",
});
```

Implementation note: short, event-driven animations are easier to maintain than always-running loops.

### 5) [tippy.js](https://atomiks.github.io/tippyjs/)

Use case: give extra context for terms without cluttering the page.

<span class="tip-demo">
  Hover <span data-tip content="Tooltip content can include tips, definitions, or keyboard hints.">this term</span>
  for a tooltip.
</span>

```js
window.tippy("[data-tip]", {
  theme: "custom-pink",
  animation: "shift-away",
});
```

Implementation note: place tooltips on advanced terms, icons, and compact controls.

### 6) [Matter.js](https://brm.io/matter-js/)

Use case: add beginner-friendly physics interactions for games, labs, or challenge pages.

<div class="matter-controls">
  <button class="mini-btn" on:click={dropMatterShape}>Drop shape</button>
  <button class="mini-btn" on:click={initMatterDemo}>Reset physics world</button>
</div>
<div class="matter-host" bind:this={matterHost} />

```js
const engine = Matter.Engine.create();
const render = Matter.Render.create({
  element: mountNode,
  engine,
  options: { width: 320, height: 220, wireframes: false },
});

Matter.Composite.add(engine.world, [
  Matter.Bodies.rectangle(160, 240, 320, 40, { isStatic: true }),
  Matter.Bodies.circle(160, 30, 16, { restitution: 0.8 }),
]);

Matter.Runner.run(Matter.Runner.create(), engine);
Matter.Render.run(render);
```

Implementation note: always clean up engine/runner/render when unmounting to avoid memory leaks.

### 7) [Matter.js DOM Physics](https://brm.io/matter-js/) - Easter Egg

Use case: A fun trick to turn all the text on the page into falling blocks just to mess around.

<div class="page-destroy-controls controls">
  <button class="mini-btn" on:click={triggerPageDestroy}>Destroy Page</button>
  <button class="mini-btn" on:click={resetPageDestroy}>Reset Layout</button>
</div>

## Interactive section for student audiences

This section combines:

- pointer-based particle feedback,
- hover depth on cards,
- and event-triggered animation.

<div class="playground" bind:this={preview} on:pointermove={makeSparkle} role="presentation">
  {#each sparkles as sparkle (sparkle.id)}
    <span class="sparkle" style="left:{sparkle.x}px; top:{sparkle.y}px;">{sparkle.char}</span>
  {/each}

  <div class="card-grid">
    <div class="tilt-card">
      <h3>Challenge mode</h3>
      <p>Add a button that increases a visible score and triggers confetti every 5 points.</p>
    </div>
    <div class="tilt-card">
      <h3>Tooltip hints</h3>
      <p>Use tippy.js to explain advanced words while keeping the layout clean.</p>
    </div>
    <div class="tilt-card">
      <h3>Progress feedback</h3>
      <p>Use anime.js to pulse status icons when tasks are complete.</p>
    </div>
  </div>
</div>

## Suggested roadmap for beginners

1. Start with one library and one component.
2. Verify behavior on desktop and mobile.
3. Add one performance check (FPS feel, stutter, input delay).
4. Add one accessibility check (contrast, tooltip readability, motion tolerance).
5. Scale to additional sections only after the first one is stable.

## Debugging checklist

- Effect not running? Check script load order and `window.LibraryName`.
- Tooltip not showing? Ensure selector matches existing elements.
- Animation jitter? Reduce particle count or duration.
- Layout shifts? Keep containers fixed in size where possible.
{:else}
  <div class="destroyed-state">
    <h3>Blog post is currently destroyed.</h3>
    <p>Click "Rebuild blog post" to remount the full content and all demos.</p>
  </div>
{/if}

<style>
