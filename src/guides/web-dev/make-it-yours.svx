    font-size: 0.8rem;
  }

  .blog-bg {
    position: fixed;
    inset: 0;
    z-index: -15;
    pointer-events: none;
    transition: background 250ms ease;
  }

  .blog-bg.grid {
    background-color: #0b1220;
    background-image:
      linear-gradient(to right, rgba(148, 163, 184, 0.16) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(148, 163, 184, 0.16) 1px, transparent 1px);
    background-size: 24px 24px;
  }

  .blog-bg.dots {
    background:
      radial-gradient(circle at 1px 1px, rgba(244, 114, 182, 0.55) 1.4px, transparent 0) 0 0 / 20px
        20px,
      #0b1220;
  }

  .blog-bg.waves {
    background:
      radial-gradient(100% 60% at 0% 0%, rgba(244, 114, 182, 0.26) 0%, transparent 80%),
      radial-gradient(100% 60% at 100% 0%, rgba(167, 139, 250, 0.24) 0%, transparent 80%),
      #0b1220;
  }

  .controls {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0.9rem 0 1.2rem;
  }

  .lifecycle-controls {
    display: flex;
    gap: 0.5rem;
    margin: 0.6rem 0 1rem;
    flex-wrap: wrap;
  }

  .controls button,
  .mini-btn {
    border: 1px solid #64748b;
    border-radius: 0.5rem;
    padding: 0.35rem 0.7rem;
    background: #0f172a;
    color: #f8fafc;
    transition: transform 120ms ease;
  }

  .controls button:hover,
  .mini-btn:hover {
    transform: translateY(-1px);
  }

  .controls button.active {
    border-color: #f472b6;
    background: #1e1b4b;
  }

  .typed-line {
    display: inline-block;
    margin-top: 0.3rem;
  }

  .typed-target {
    color: #f9a8d4;
    font-weight: 600;
  }

  .tip-demo {
    display: inline-block;
    margin-top: 0.3rem;
  }

  .tip-demo [data-tip] {
    text-decoration: underline;
    text-decoration-style: wavy;
    cursor: help;
    color: #f9a8d4;
  }

  .tilt-demo {
    display: inline-block;
    margin-top: 0.35rem;
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    background: rgba(30, 27, 75, 0.85);
    border: 1px solid #a78bfa;
    color: #ede9fe;
  }

  .anime-demo-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.35rem;
  }

  .anime-dot {
    width: 18px;
    height: 18px;
    border-radius: 999px;
    background: linear-gradient(135deg, #f472b6, #a78bfa);
    display: inline-block;
  }

  .matter-controls {
    display: flex;
    gap: 0.5rem;
    margin: 0.4rem 0 0.7rem;
    flex-wrap: wrap;
  }

  .matter-host {
    width: 100%;
    min-height: 220px;
    border: 1px solid #475569;
    border-radius: 0.65rem;
    overflow: hidden;
    background: rgba(15, 23, 42, 0.55);
    margin-bottom: 0.8rem;
  }

  .destroyed-state {
    border: 1px solid #ef4444;
    border-radius: 0.75rem;
    background: rgba(127, 29, 29, 0.22);
    padding: 0.8rem;
  }

  .playground {
    margin-top: 1rem;
    border: 1px solid #334155;
    border-radius: 0.8rem;
    padding: 1rem;
    background: rgba(2, 6, 23, 0.55);
    position: relative;
    overflow: hidden;
  }

  .card-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(165px, 1fr));
    gap: 0.8rem;
  }

  .tilt-card {
    border: 1px solid rgba(148, 163, 184, 0.5);
    border-radius: 0.7rem;
    padding: 0.8rem;
    background: rgba(15, 23, 42, 0.8);
    backdrop-filter: blur(2px);
  }

  .tilt-card h3 {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    color: #fbcfe8;
  }

  .tilt-card p {
    margin: 0;
    font-size: 0.9rem;
    color: #e2e8f0;
  }

  .sparkle {
    position: absolute;
    transform: translate(-50%, -50%);
    pointer-events: none;
    animation: pop 700ms ease forwards;
    z-index: 3;
    font-weight: 700;
  }

  @keyframes pop {
    from {
      opacity: 1;
      transform: translate(-50%, -50%) scale(0.45);
    }
    to {
      opacity: 0;
      transform: translate(-50%, calc(-50% - 18px)) scale(1.15);
    }
  }
</style>
